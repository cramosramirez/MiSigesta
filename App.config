<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <connectionStrings>
    <!--
      Ajustar según el servidor SQL Server de producción:
      Server   = nombre del servidor o IP
      Database = nombre de la base de datos (PH2)
      User Id  = usuario SQL Server
      Password = contraseña
    -->
    <add name="SistemaContable"
         connectionString="Server=.\SQLEXPRESS2022;Database=PH2;User Id=sa;Password=prueba;MultipleActiveResultSets=true;Connection Timeout=30;"
         providerName="System.Data.SqlClient"/>
  </connectionStrings>
  <appSettings>
    <!-- Nombre de la empresa mostrado en el sistema -->
    <add key="NombreEmpresa"  value="INJIBOA"/>
	<!-- API de consulta del Ministerio de Hacienda -->
	<add key="UrlConsultaMH" value="https://admin.factura.gob.sv/prod/consultas/publica/simple/1?"/>
	<!-- API de consulta del Ministerio de Hacienda -->
	<add key="CodigoCCJIBOA" value="226663-4"/>
    <!--
      Ruta UNC al servidor de actualizaciones.
      Dejar vacío para deshabilitar la auto-actualización.
      Ejemplo: \\SERVIDOR\SistemaContable\
    -->
    <add key="RutaServidor"   value=""/>
	<add key="FontSize"       value="10"/>
  </appSettings>
</configuration>
